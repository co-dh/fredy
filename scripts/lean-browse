#!/bin/sh
# lean-browse [initial-query] — fzf over the Freyd declaration graph (graph/*.tsv).
# keys: enter = open in helix   ^u = what it uses   ^r = what uses it   ^a = back to all
# Regenerate the data:  lake env lean --run scripts/ExtractGraph.lean
cd "$(dirname "$0")/.." || exit 1
D=graph
S=$(realpath "$0")   # fzf bindings run with the pane's cwd; be absolute
[ -r "$D/decls.tsv" ] || { echo "no $D/decls.tsv — run: lake env lean --run scripts/ExtractGraph.lean" >&2; exit 1; }

case "$1" in
preview)
  n=$2
  awk -F'\t' -v n="$n" '$1==n{printf "%s  %s:%s\n",$2,$3,$4; if($6!="")print $6; if($5!="")print ": "$5; exit}' "$D/decls.tsv"
  printf '\n─ uses ─\n'
  awk -F'\t' -v n="$n" '$1==n{c++; if(c<=25)print "  "$2} END{if(c>25)print "  … "c-25" more"}' "$D/deps.tsv"
  printf '─ used by ─\n'
  awk -F'\t' -v n="$n" '$2==n{c++; if(c<=25)print "  "$1} END{if(c>25)print "  … "c-25" more"}' "$D/deps.tsv"
  f=$(awk -F'\t' -v n="$n" '$1==n{print $3; exit}' "$D/decls.tsv")
  l=$(awk -F'\t' -v n="$n" '$1==n{print $4; exit}' "$D/decls.tsv")
  [ -n "$f" ] || exit 0
  printf '─ %s:%s ─\n' "$f" "$l"
  bat --color=always --style=plain --line-range "$l:$((l+40))" "$f" 2>/dev/null ||
    sed -n "$l,$((l+40))p" "$f"
  ;;
uses)   awk -F'\t' -v n="$2" 'NR==FNR{if($1==n)k[$2]=1;next} $1 in k' "$D/deps.tsv" "$D/decls.tsv" ;;
usedby) awk -F'\t' -v n="$2" 'NR==FNR{if($2==n)k[$1]=1;next} $1 in k' "$D/deps.tsv" "$D/decls.tsv" ;;
*)
  exec fzf -d '\t' --with-nth 1,2,6,5 --nth 1,5,6 --query "${1:-}" --no-hscroll \
    --header 'enter:helix  ^u:uses  ^r:used-by  ^a:all   (matches name+type+doc)' \
    --preview "\"$S\" preview {1}" --preview-window 'down,60%,border-top,wrap' \
    --bind "enter:execute(helix {3}:{4} </dev/tty >/dev/tty)" \
    --bind "ctrl-u:reload(\"$S\" uses {1})+first" \
    --bind "ctrl-r:reload(\"$S\" usedby {1})+first" \
    --bind "ctrl-a:reload(cat $D/decls.tsv)+first" \
    <"$D/decls.tsv"
  ;;
esac
