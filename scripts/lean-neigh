#!/bin/sh
# lean-neigh NAME [K] — K-hop (default 2) dependency neighborhood of a declaration.
# Writes graph/neigh.dot (render: dot -Tsvg graph/neigh.dot -o neigh.svg) and, if
# graphviz is installed, graph/neigh.svg; always prints uses/used-by text trees.
cd "$(dirname "$0")/.." || exit 1
n=$1; k=${2:-2}; D=graph
[ -n "$n" ] || { echo "usage: lean-neigh NAME [K]" >&2; exit 1; }
grep -qP "^\Q$n\E\t" "$D/decls.tsv" || { echo "unknown declaration: $n" >&2; exit 1; }

awk -F'\t' -v root="$n" -v k="$k" '
  {d[$1]=d[$1]" "$2; r[$2]=r[$2]" "$1}
  END{
    seen[root]=1; frontier[root]=1
    for(i=0;i<k;i++){
      for(v in frontier){
        split(d[v],a," "); for(j in a) if(a[j]!="" && !(a[j] in seen)){seen[a[j]]=1; nxt[a[j]]=1}
        split(r[v],b," "); for(j in b) if(b[j]!="" && !(b[j] in seen)){seen[b[j]]=1; nxt[b[j]]=1}
      }
      delete frontier; for(v in nxt) frontier[v]=1; delete nxt
    }
    print "digraph G {"
    print "  rankdir=LR; node [shape=box, fontsize=10];"
    printf "  \"%s\" [style=filled, fillcolor=gold];\n", root
    for(v in seen){ split(d[v],a," ")
      for(j in a) if(a[j]!="" && (a[j] in seen)) printf "  \"%s\" -> \"%s\";\n", v, a[j] }
    print "}"
  }' "$D/deps.tsv" > "$D/neigh.dot"
echo "$D/neigh.dot"
command -v dot >/dev/null && dot -Tsvg "$D/neigh.dot" -o "$D/neigh.svg" && echo "$D/neigh.svg"

awk -F'\t' -v root="$n" -v k="$k" '
  {d[$1]=d[$1]"\t"$2; r[$2]=r[$2]"\t"$1}
  function tree(v, depth, dir,   a, i, m, s) {
    for(i=0;i<depth;i++) m=m"  "
    print m v
    if (depth >= k) return
    s = (dir=="d") ? d[v] : r[v]
    split(s, a, "\t")
    for(i in a) if(a[i]!="") tree(a[i], depth+1, dir)
  }
  END{
    print "── uses (depth " k ") ──";    tree(root, 0, "d")
    print "── used by (depth " k ") ──"; tree(root, 0, "r")
  }' "$D/deps.tsv"
