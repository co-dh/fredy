/-
  Freyd & Scedrov, *Categories and Allegories* §2.216 / §2.342
  MATRIX ALLEGORY  Mat 𝒜  over a distributive allegory 𝒜.

  Objects  = Fin-n-indexed families of 𝒜-objects  (MatObj 𝒜).
  Morphisms = n×m matrices of base morphisms       (MatHom X Y).

  No Finset/Fintype/LinearOrder from Std — uses only List, Fin n, List.ofFn.
-/

import Fredy.S1_1
import Fredy.S2_1
import Fredy.S2_2
import Fredy.S2_3

universe v u

open Freyd Freyd.Alg

namespace Freyd.Alg.Mat

/-! ## §A  List-based finite join  in a distributive allegory

  `listJoin' l` = right-fold of `∪` with unit `𝟘`. -/

section ListJoin

variable {𝒜 : Type u} [DistributiveAllegory 𝒜]

def listJoin' {a b : 𝒜} : List (a ⟶ b) → a ⟶ b
  | []      => 𝟘
  | x :: xs => x ∪ listJoin' xs

@[simp] theorem foldJoin_empty {a b : 𝒜} {J : Type u} (f : J → (a ⟶ b)) :
    foldJoin ∅ f = 𝟘 := Finset.fold_empty

theorem foldJoin_insert {a b : 𝒜} {J : Type u} {s : Finset J} {j : J}
    (hj : j ∉ s) (f : J → (a ⟶ b)) :
    foldJoin (insert j s) f = f j ∪ foldJoin s f := by
  simp [foldJoin, Finset.fold_insert hj, DistributiveAllegory.union_comm]

theorem le_foldJoin {a b : 𝒜} {J : Type u} {s : Finset J}
    (f : J → (a ⟶ b)) {j : J} (hj : j ∈ s) : f j ⊑ foldJoin s f := by
  induction s using Finset.induction_on with
  | empty => exact absurd hj (Finset.not_mem_empty j)
  | insert ha ih =>
    rename_i s' a' ha; rw [foldJoin_insert ha]
    rcases Finset.mem_insert.mp hj with rfl | hjs
    · exact le_union_left _ _
    · exact le_trans (ih hjs) (le_union_right _ _)

theorem foldJoin_le {a b : 𝒜} {J : Type u} {s : Finset J} (f : J → (a ⟶ b))
    {T : a ⟶ b} (h : ∀ j ∈ s, f j ⊑ T) : foldJoin s f ⊑ T := by
  induction s using Finset.induction_on with
  | empty => simp; exact zero_le T
  | insert ha ih =>
    rename_i s' a' ha; rw [foldJoin_insert ha]
    exact union_lub (h a' (Finset.mem_insert_self a' s'))
      (ih (fun j hj => h j (Finset.mem_insert_of_mem hj)))

theorem comp_foldJoin {a b c : 𝒜} {J : Type u} {s : Finset J}
    (R : a ⟶ b) (f : J → (b ⟶ c)) :
    R ≫ foldJoin s f = foldJoin s (fun j => R ≫ f j) := by
  induction s using Finset.induction_on with
  | empty => simp; exact DistributiveAllegory.comp_zero R
  | insert ha ih =>
    rename_i s' a' ha; rw [foldJoin_insert ha, foldJoin_insert ha,
        DistributiveAllegory.comp_union_distrib, ih]

theorem foldJoin_comp {a b c : 𝒜} {J : Type u} {s : Finset J}
    (f : J → (a ⟶ b)) (R : b ⟶ c) :
    foldJoin s f ≫ R = foldJoin s (fun j => f j ≫ R) := by
  induction s using Finset.induction_on with
  | empty => simp; exact DistributiveAllegory.zero_comp R
  | insert ha ih =>
    rename_i s' a' ha; rw [foldJoin_insert ha, foldJoin_insert ha, union_comp_distrib, ih]

/-- Finite join `finJoin f = ⨆_{j : J} f j`. -/
def finJoin {a b : 𝒜} {J : Type u} [Fintype J] (f : J → (a ⟶ b)) : a ⟶ b :=
  foldJoin Finset.univ f

theorem le_finJoin {a b : 𝒜} {J : Type u} [Fintype J] (f : J → (a ⟶ b)) (j : J) :
    f j ⊑ finJoin f := le_foldJoin f (Finset.mem_univ j)

theorem finJoin_le {a b : 𝒜} {J : Type u} [Fintype J] (f : J → (a ⟶ b))
    {T : a ⟶ b} (h : ∀ j, f j ⊑ T) : finJoin f ⊑ T :=
  foldJoin_le f (fun j _ => h j)

theorem finJoin_mono {a b : 𝒜} {J : Type u} [Fintype J] {f g : J → (a ⟶ b)}
    (h : ∀ j, f j ⊑ g j) : finJoin f ⊑ finJoin g :=
  finJoin_le f (fun j => le_trans (h j) (le_finJoin g j))

theorem comp_finJoin {a b c : 𝒜} {J : Type u} [Fintype J]
    (R : a ⟶ b) (f : J → (b ⟶ c)) :
    R ≫ finJoin f = finJoin (fun j => R ≫ f j) := comp_foldJoin R f

theorem finJoin_comp {a b c : 𝒜} {J : Type u} [Fintype J]
    (f : J → (a ⟶ b)) (R : b ⟶ c) :
    finJoin f ≫ R = finJoin (fun j => f j ≫ R) := foldJoin_comp f R

theorem recip_finJoin {a b : 𝒜} {J : Type u} [Fintype J] (f : J → (a ⟶ b)) :
    (finJoin f)° = finJoin (fun j => (f j)°) := by
  apply le_antisymm
  · rw [recip_le_iff]; apply finJoin_le; intro j
    exact (recip_le_iff.mp (le_finJoin _ j)) |>.symm ▸ by
      rw [Allegory.recip_recip]; exact le_finJoin f j
  · apply finJoin_le; intro j; exact recip_mono (le_finJoin f j)

theorem inter_finJoin {a b : 𝒜} {J : Type u} [Fintype J] (T : a ⟶ b) (f : J → (a ⟶ b)) :
    T ∩ finJoin f = finJoin (fun j => T ∩ f j) := by
  simp only [finJoin, foldJoin]
  induction Finset.univ using Finset.induction_on with
  | empty =>
    simp [Finset.fold_empty]
    exact le_antisymm (inter_lb_right T 𝟘) (le_inter (zero_le T) (le_refl 𝟘))
  | insert ha ih =>
    rename_i s a' ha
    rw [Finset.fold_insert ha, Finset.fold_insert ha,
        ← DistributiveAllegory.inter_union_distrib, ih]

end FinJoin

/-! ## §B  Finite meet  ⋀_k f k  in an allegory

  We use `foldMeet s hne f` = fold of `∩` starting from `f (min' s)`,
  folding over `s.erase (min' s)`.  Key result: `T ⊑ foldMeet s hne f ↔ ∀ k ∈ s, T ⊑ f k`.
-/

section FinMeet

variable {𝒜 : Type u} [Allegory 𝒜]

/-- `foldMeet s hne f` = fold of `∩` over `s.erase (min' s)`, starting from `f (min' s)`.
    This avoids a "unit" for `∩` (no top element assumed). -/
def foldMeet {a b : 𝒜} {K : Type u} [LinearOrder K]
    (s : Finset K) (hne : s.Nonempty) (f : K → (a ⟶ b)) : a ⟶ b :=
  (s.erase (s.min' hne)).fold (· ∩ ·) (f (s.min' hne)) f

private theorem foldMeet_le_of_mem {a b : 𝒜} {K : Type u} [LinearOrder K]
    (s : Finset K) (hne : s.Nonempty) (f : K → (a ⟶ b)) {k : K} (hk : k ∈ s) :
    foldMeet s hne f ⊑ f k := by
  simp only [foldMeet]
  -- We prove: fold (∩) init f s' ⊑ f k whenever k ∈ s' or init = f k.
  suffices h : ∀ (s' : Finset K) (init : a ⟶ b),
      (k ∈ s' ∨ init = f k) → s'.fold (· ∩ ·) init f ⊑ f k from
    h _ _ (by
      rcases eq_or_ne k (s.min' hne) with rfl | hne'
      · right; rfl
      · left; exact Finset.mem_erase.mpr ⟨hne', hk⟩)
  intro s'
  induction s' using Finset.induction_on with
  | empty =>
    intro init hk'
    simp [Finset.fold_empty]
    rcases hk' with h | rfl
    · exact absurd h (Finset.not_mem_empty k)
    · exact le_refl _
  | insert ha ih =>
    rename_i s'' a'' ha
    intro init hk'
    rw [Finset.fold_insert ha]
    rcases hk' with hmem | rfl
    · rcases Finset.mem_insert.mp hmem with rfl | hmem'
      · exact inter_lb_left _ _
      · exact le_trans (inter_lb_right _ _) (ih init (Or.inl hmem'))
    · exact le_trans (inter_lb_right _ _) (ih _ (Or.inr rfl))

private theorem le_foldMeet_of_all {a b : 𝒜} {K : Type u} [LinearOrder K]
    (s : Finset K) (hne : s.Nonempty) (f : K → (a ⟶ b)) {T : a ⟶ b}
    (h : ∀ k ∈ s, T ⊑ f k) : T ⊑ foldMeet s hne f := by
  simp only [foldMeet]
  -- T ⊑ f (min' s)  and  T ⊑ each f k for k ∈ s.erase(min' s).
  -- By induction: T ⊑ fold (∩) init f s' whenever T ⊑ init and ∀ k ∈ s', T ⊑ f k.
  suffices ∀ (s' : Finset K) (init : a ⟶ b), T ⊑ init → (∀ k ∈ s', T ⊑ f k) →
      T ⊑ s'.fold (· ∩ ·) init f from
    this _ _ (h _ (Finset.min'_mem s hne))
      (fun k hk => h k (Finset.mem_of_mem_erase hk))
  intro s'
  induction s' using Finset.induction_on with
  | empty => intro init hi _; simpa [Finset.fold_empty]
  | insert ha ih =>
    rename_i s'' a' ha
    intro init hi hs'
    rw [Finset.fold_insert ha]
    exact le_inter (hs' a' (Finset.mem_insert_self a' s''))
      (ih init hi (fun k hk => hs' k (Finset.mem_insert_of_mem hk)))

/-- The key characterization: `T ⊑ foldMeet s hne f ↔ ∀ k ∈ s, T ⊑ f k`. -/
theorem le_foldMeet_iff {a b : 𝒜} {K : Type u} [LinearOrder K]
    (s : Finset K) (hne : s.Nonempty) (f : K → (a ⟶ b)) {T : a ⟶ b} :
    T ⊑ foldMeet s hne f ↔ ∀ k ∈ s, T ⊑ f k :=
  ⟨fun h k hk => le_trans h (foldMeet_le_of_mem s hne f hk),
   le_foldMeet_of_all s hne f⟩

/-- Finite meet `finMeet f = ⋀_{k : K} f k` (requires `Nonempty K`). -/
noncomputable def finMeet {a b : 𝒜} {K : Type u} [Fintype K] [Nonempty K]
    (f : K → (a ⟶ b)) : a ⟶ b :=
  letI : LinearOrder K := Classical.linearOrder K
  foldMeet Finset.univ Finset.univ_nonempty f

theorem finMeet_le {a b : 𝒜} {K : Type u} [Fintype K] [Nonempty K]
    (f : K → (a ⟶ b)) (k : K) : finMeet f ⊑ f k := by
  simp only [finMeet]
  exact foldMeet_le_of_mem _ _ _ (Finset.mem_univ k)

theorem le_finMeet {a b : 𝒜} {K : Type u} [Fintype K] [Nonempty K]
    (f : K → (a ⟶ b)) {T : a ⟶ b} (h : ∀ k, T ⊑ f k) : T ⊑ finMeet f := by
  simp only [finMeet]
  exact le_foldMeet_of_all _ _ _ (fun k _ => h k)

theorem le_finMeet_iff {a b : 𝒜} {K : Type u} [Fintype K] [Nonempty K]
    (f : K → (a ⟶ b)) {T : a ⟶ b} :
    T ⊑ finMeet f ↔ ∀ k, T ⊑ f k :=
  ⟨fun h k => le_trans h (finMeet_le f k), le_finMeet f⟩

end FinMeet

/-! ## §C  MatObj and MatHom -/

/-- An object of `Mat 𝒜`: a finite-indexed family of 𝒜-objects. -/
structure MatObj (𝒜 : Type u) where
  idx : Type u
  fin : Fintype idx
  dec : DecidableEq idx
  obj : idx → 𝒜

attribute [instance] MatObj.fin MatObj.dec

/-- Morphisms in `Mat 𝒜`. -/
def MatHom [Cat.{v} 𝒜] (X Y : MatObj 𝒜) : Type (max u v) :=
  (i : X.idx) → (j : Y.idx) → X.obj i ⟶ Y.obj j

/-! ## §D  Category structure on MatObj 𝒜 -/

section MatCat

variable {𝒜 : Type u} [DistributiveAllegory 𝒜]

def matId (X : MatObj 𝒜) : MatHom X X :=
  fun i j => if h : i = j then h ▸ Cat.id (X.obj i) else 𝟘

def matComp {X Y Z : MatObj 𝒜} (M : MatHom X Y) (N : MatHom Y Z) : MatHom X Z :=
  fun i k => finJoin (fun j => M i j ≫ N j k)

theorem matId_comp {X Y : MatObj 𝒜} (M : MatHom X Y) : matComp (matId X) M = M := by
  funext i k; simp only [matComp, matId]
  apply le_antisymm
  · apply finJoin_le; intro j
    by_cases h : i = j
    · subst h; simp [Cat.id_comp]
    · simp [h]; exact zero_le _
  · have : Cat.id _ = (if h : i = i then h ▸ Cat.id (X.obj i) else 𝟘) := by simp
    calc M i k = Cat.id _ ≫ M i k := (Cat.id_comp _).symm
      _ = (if h : i = i then h ▸ Cat.id (X.obj i) else 𝟘) ≫ M i k := by rw [this]
      _ ⊑ finJoin (fun j => (if h : i = j then h ▸ Cat.id (X.obj i) else 𝟘) ≫ M j k) :=
          le_finJoin _ i

theorem matComp_id {X Y : MatObj 𝒜} (M : MatHom X Y) : matComp M (matId Y) = M := by
  funext i k; simp only [matComp, matId]
  apply le_antisymm
  · apply finJoin_le; intro j
    by_cases h : j = k
    · subst h; simp [Cat.comp_id]
    · simp [h]; exact zero_le _
  · have : Cat.id _ = (if h : k = k then h ▸ Cat.id (Y.obj k) else 𝟘) := by simp
    calc M i k = M i k ≫ Cat.id _ := (Cat.comp_id _).symm
      _ = M i k ≫ (if h : k = k then h ▸ Cat.id (Y.obj k) else 𝟘) := by rw [this]
      _ ⊑ finJoin (fun j => M i j ≫ (if h : j = k then h ▸ Cat.id (Y.obj j) else 𝟘)) :=
          le_finJoin _ k

theorem matComp_assoc {W X Y Z : MatObj 𝒜}
    (M : MatHom W X) (N : MatHom X Y) (P : MatHom Y Z) :
    matComp (matComp M N) P = matComp M (matComp N P) := by
  funext i l; simp only [matComp]
  apply le_antisymm
  · apply finJoin_le; intro k
    rw [finJoin_comp]; apply finJoin_le; intro j
    rw [Cat.assoc]
    exact le_trans (comp_mono_left _ (le_finJoin _ k)) (le_finJoin _ j)
  · apply finJoin_le; intro j
    rw [comp_finJoin]; apply finJoin_le; intro k
    rw [← Cat.assoc]
    exact le_trans (comp_mono_right _ (le_finJoin _ j)) (le_finJoin _ k)

instance instCatMatObj : Cat.{max u v} (MatObj 𝒜) where
  Hom     := MatHom
  id      := matId
  comp    := matComp
  id_comp := matId_comp
  comp_id := matComp_id
  assoc   := matComp_assoc

end MatCat

/-! ## §E  Allegory instance -/

section MatAllegory

variable {𝒜 : Type u} [DistributiveAllegory 𝒜]

def matRecip {X Y : MatObj 𝒜} (M : MatHom X Y) : MatHom Y X :=
  fun j i => (M i j)°

def matInter {X Y : MatObj 𝒜} (M N : MatHom X Y) : MatHom X Y :=
  fun i j => M i j ∩ N i j

theorem matRecip_comp {X Y Z : MatObj 𝒜} (M : MatHom X Y) (N : MatHom Y Z) :
    matRecip (matComp M N) = matComp (matRecip N) (matRecip M) := by
  funext k i; simp only [matRecip, matComp, recip_finJoin]
  congr 1; funext j; rw [Allegory.recip_comp]

/-- Semi-distributivity entrywise — trivial since only ⊑ directions matter. -/
theorem matSemidistrib {X Y Z : MatObj 𝒜} (R : MatHom X Y) (S T : MatHom Y Z) :
    matComp R (matInter S T) =
      matInter (matInter (matComp R S) (matComp R (matInter S T))) (matComp R T) := by
  funext i k; simp only [matComp, matInter]
  apply le_antisymm
  · apply le_inter
    · apply le_inter _ (le_refl _)
      exact finJoin_mono (fun j => comp_mono_left _ (inter_lb_left _ _))
    · exact finJoin_mono (fun j => comp_mono_left _ (inter_lb_right _ _))
  · exact le_trans (inter_lb_left _ _) (inter_lb_right _ _)

/-- Modular law: uses `inter_finJoin` to push `∩` inside the join, then applies
    the base modular law entry-wise. -/
theorem matModular {X Y Z : MatObj 𝒜} (R : MatHom X Y) (S : MatHom Y Z) (T : MatHom X Z) :
    matInter (matComp R S) T =
      matInter (matInter (matComp R S) T)
               (matComp (matInter R (matComp T (matRecip S))) S) := by
  funext i k; simp only [matInter, matComp, matRecip]
  apply le_antisymm
  · apply le_inter (le_refl _)
    -- (⨆_j R_{ij}≫S_{jk}) ∩ T_{ik} ⊑ ⨆_j (R_{ij} ∩ ⨆_l T_{il}≫(S_{jl})°) ≫ S_{jk}
    rw [Allegory.inter_comm, inter_finJoin]
    apply finJoin_mono; intro j
    rw [Allegory.inter_comm]
    -- base modular_le + monotone: T_{ik}(S_{jk})° ⊑ ⨆_l T_{il}(S_{jl})°
    exact le_trans (modular_le (R i j) (S j k) (T i k))
      (comp_mono_right (le_inter (inter_lb_left _ _)
        (le_trans (inter_lb_right _ _) (le_finJoin (fun l => T i l ≫ (S j l)°) k))) _)
  · exact le_trans (inter_lb_left _ _) (le_refl _)

/-- §2.216: `Mat 𝒜` is an allegory. -/
instance instAllegoryMat : Allegory (MatObj 𝒜) where
  recip       := matRecip
  inter       := matInter
  recip_recip := fun M => by funext i j; simp [matRecip, Allegory.recip_recip]
  recip_comp  := matRecip_comp
  recip_inter := fun M N => by funext j i; simp [matRecip, matInter, Allegory.recip_inter]
  inter_idem  := fun M => by funext i j; simp [matInter, Allegory.inter_idem]
  inter_comm  := fun M N => by funext i j; simp [matInter, Allegory.inter_comm]
  inter_assoc := fun M N P => by funext i j; simp [matInter, Allegory.inter_assoc]
  semidistrib := matSemidistrib
  modular     := matModular

end MatAllegory

/-! ## §F  Distributive allegory instance -/

section MatDistributive

variable {𝒜 : Type u} [DistributiveAllegory 𝒜]

def matZero {X Y : MatObj 𝒜} : MatHom X Y := fun _i _j => 𝟘
def matUnion {X Y : MatObj 𝒜} (M N : MatHom X Y) : MatHom X Y := fun i j => M i j ∪ N i j

theorem matZero_comp {X Y Z : MatObj 𝒜} (N : MatHom Y Z) :
    matComp (matZero (X := X)) N = matZero := by
  funext i k; simp only [matComp, matZero, finJoin, foldJoin]
  induction Finset.univ using Finset.induction_on with
  | empty => simp
  | insert ha ih =>
    rename_i s a' ha
    rw [Finset.fold_insert ha, DistributiveAllegory.zero_comp, ih,
        DistributiveAllegory.union_idem]

theorem matComp_zero {X Y Z : MatObj 𝒜} (M : MatHom X Y) :
    matComp M (matZero (Y := Z)) = matZero := by
  funext i k; simp only [matComp, matZero, finJoin, foldJoin]
  induction Finset.univ using Finset.induction_on with
  | empty => simp
  | insert ha ih =>
    rename_i s a' ha
    rw [Finset.fold_insert ha, DistributiveAllegory.comp_zero, ih,
        DistributiveAllegory.union_idem]

theorem matComp_union_distrib {X Y Z : MatObj 𝒜} (M : MatHom X Y) (N P : MatHom Y Z) :
    matComp M (matUnion N P) = matUnion (matComp M N) (matComp M P) := by
  funext i k; simp only [matComp, matUnion]
  rw [show (fun j => M i j ≫ (N j k ∪ P j k)) =
        (fun j => M i j ≫ N j k ∪ M i j ≫ P j k) from
    funext fun j => DistributiveAllegory.comp_union_distrib _ _ _]
  apply le_antisymm
  · apply finJoin_le; intro j
    exact union_lub (le_trans (le_union_left _ _) (le_finJoin _ j))
                    (le_trans (le_union_right _ _) (le_finJoin _ j))
  · exact union_lub (finJoin_mono (fun j => le_union_left _ _))
                    (finJoin_mono (fun j => le_union_right _ _))

/-- §2.216: `Mat 𝒜` is a distributive allegory. -/
instance instDistributiveAllegoryMat : DistributiveAllegory (MatObj 𝒜) :=
  { instAllegoryMat with
    zero  := @matZero 𝒜 _
    union := @matUnion 𝒜 _
    zero_comp  := fun N => matZero_comp N
    comp_zero  := fun M => matComp_zero M
    union_idem := fun M   => by funext i j; simp [matUnion, DistributiveAllegory.union_idem]
    union_comm := fun M N => by funext i j; simp [matUnion, DistributiveAllegory.union_comm]
    union_assoc := fun M N P => by
      funext i j; simp [matUnion, DistributiveAllegory.union_assoc]
    union_inter_absorb := fun M N => by
      funext i j; simp [matUnion, matInter, DistributiveAllegory.union_inter_absorb]
    inter_union_absorb := fun M N => by
      funext i j; simp [matUnion, matInter, DistributiveAllegory.inter_union_absorb]
    comp_union_distrib := matComp_union_distrib
    inter_union_distrib := fun M N P => by
      funext i j; simp [matUnion, matInter, DistributiveAllegory.inter_union_distrib]
    zero_union := fun M => by
      funext i j; simp [matUnion, matZero, DistributiveAllegory.zero_union] }

end MatDistributive

/-! ## §G  Division allegory instance (§2.342)

  BOOK §2.342: "The positive reflection A⁺ is a division allegory."
  (R/S)_{ij} = ⋀_{k : Z.idx} (R_{ik} / S_{jk}).

  The adjointness T ⊑ R/S ↔ TS ⊑ R lifts from 𝒜 to Mat 𝒜:
    T ⊑ matDiv R S  (entry-wise)
    ↔ ∀ i j,  T_{ij} ⊑ ⋀_k (R_{ik}/S_{jk})
    ↔ ∀ i j k,  T_{ij} ⊑ R_{ik}/S_{jk}
    ↔ ∀ i j k,  T_{ij} ≫ S_{jk} ⊑ R_{ik}
    ↔ ∀ i k,  ⨆_j (T_{ij} ≫ S_{jk}) ⊑ R_{ik}
    ↔ matComp T S ⊑ R  (entry-wise in Mat 𝒜).

  NOTE: `foldMeet` requires `Z.idx` to be nonempty (it is the intermediate object in
  the composition).  If `Z.idx = ∅` then there is no k, so `⨆_j T_{ij}≫S_{jk} = 𝟘 ⊑ R`
  always, and the adjoint should be the top (any morphism works).  We use `Classical.choice`
  to provide a value in that case. -/

section MatDivision

variable {𝒜 : Type u} [DivisionAllegory 𝒜]

/-- Matrix division: `(R/S)_{ij} = ⋀_k (R_{ik}/S_{jk})`. -/
noncomputable def matDiv {X Y Z : MatObj 𝒜} (R : MatHom X Z) (S : MatHom Y Z) : MatHom X Y :=
  fun i j =>
    letI : LinearOrder Z.idx := Classical.linearOrder Z.idx
    if hne : (Finset.univ (α := Z.idx)).Nonempty then
      foldMeet Finset.univ hne (fun k => R i k / S j k)
    else
      -- Z.idx is empty: 𝟘 ⊑ R always; any value works as adjoint.
      𝟘

-- The order on Mat 𝒜 objects: pointwise. Note: `le` in Allegory is `R ∩ S = R`.
-- For matrices: M ⊑ N means matInter M N = M, i.e., ∀ i j, M i j ∩ N i j = M i j,
-- i.e., ∀ i j, M i j ⊑ N i j.

private theorem matLe_iff {X Y : MatObj 𝒜} {M N : MatHom X Y} :
    @le _ (@instAllegoryMat 𝒜 _ X Y) M N ↔ ∀ i j, M i j ⊑ N i j := by
  simp only [le, matInter]
  constructor
  · intro h i j; exact congrFun (congrFun h i) j
  · intro h; funext i j; exact h i j

theorem matDiv_le_div {X Y Z : MatObj 𝒜} (T : MatHom X Y) (R : MatHom X Z) (S : MatHom Y Z)
    (h : @le _ (@instAllegoryMat 𝒜 _ X Z) (matComp T S) R) :
    @le _ (@instAllegoryMat 𝒜 _ X Y) T (matDiv R S) := by
  rw [matLe_iff] at h ⊢
  intro i j
  simp only [matComp] at h
  -- h: ∀ i k, finJoin (fun j => T i j ≫ S j k) ⊑ R i k
  -- Goal: T i j ⊑ matDiv R S i j = ⋀_k (R i k / S j k)
  simp only [matDiv]
  letI hlo : LinearOrder Z.idx := Classical.linearOrder Z.idx
  by_cases hne : (Finset.univ (α := Z.idx)).Nonempty
  · simp [hne]
    rw [le_foldMeet_iff]
    intro k _
    -- T i j ⊑ R i k / S j k  ↔  T i j ≫ S j k ⊑ R i k
    rw [le_div_iff]
    -- T i j ≫ S j k ⊑ finJoin (fun j' => T i j' ≫ S j' k)  ⊑  R i k
    exact le_trans (le_finJoin _ j) (h i k)
  · simp [hne]; exact zero_le _

theorem le_matDiv_comp {X Y Z : MatObj 𝒜} (R : MatHom X Z) (S : MatHom Y Z) :
    @le _ (@instAllegoryMat 𝒜 _ X Z) (matComp (matDiv R S) S) R := by
  rw [matLe_iff]; intro i k
  simp only [matComp, matDiv]
  -- Goal: finJoin (fun j => (⋀_k' R i k' / S j k') ≫ S j k) ⊑ R i k
  letI hlo : LinearOrder Z.idx := Classical.linearOrder Z.idx
  apply finJoin_le; intro j
  by_cases hne : (Finset.univ (α := Z.idx)).Nonempty
  · simp [hne]
    -- foldMeet ... f ⊑ f k (by foldMeet_le_of_mem)
    have hbelow : foldMeet Finset.univ hne (fun k' => R i k' / S j k') ⊑ R i k / S j k :=
      foldMeet_le_of_mem _ _ _ (Finset.mem_univ k)
    exact le_trans (comp_mono_right hbelow (S j k)) (div_comp_eq_le _ _)
  · simp [hne]; exact zero_le _

/-- §2.342: `Mat 𝒜` is a division allegory when `𝒜` is. -/
noncomputable instance instDivisionAllegoryMat : DivisionAllegory (MatObj 𝒜) :=
  { instDistributiveAllegoryMat with
    div         := @matDiv 𝒜 _
    div_comp_le := le_matDiv_comp
    le_div      := fun T R S h => matDiv_le_div T R S h }

end MatDivision

/-! ## §H  The 1×1 faithful embedding  A → Mat A  (§2.216 / §2.342) -/

section Embed1

variable {𝒜 : Type u} [DistributiveAllegory 𝒜]

/-- The single-object 1×1 base: `PUnit`-indexed family. -/
def unitObj (a : 𝒜) : MatObj 𝒜 :=
  { idx := PUnit, fin := inferInstance, dec := inferInstance, obj := fun _ => a }

/-- The 1×1 embedding: `embed1 R = 1×1 matrix (R)`. -/
def embed1 {a b : 𝒜} (R : a ⟶ b) : MatHom (unitObj a) (unitObj b) :=
  fun _i _j => R

/-- `embed1` is injective (faithful). -/
theorem embed1_injective {a b : 𝒜} {R S : a ⟶ b}
    (h : embed1 R = embed1 S) : R = S :=
  congrFun (congrFun h PUnit.unit) PUnit.unit

/-- `embed1` preserves composition (up to ⊑-order). -/
theorem embed1_comp {a b c : 𝒜} (R : a ⟶ b) (S : b ⟶ c) :
    embed1 (R ≫ S) = matComp (embed1 R) (embed1 S) := by
  funext i k; simp only [embed1, matComp]
  -- finJoin over PUnit has one term (at PUnit.unit).
  apply le_antisymm
  · exact le_finJoin _ PUnit.unit
  · apply finJoin_le; intro j; exact le_refl _

/-- `embed1` preserves reciprocation. -/
theorem embed1_recip {a b : 𝒜} (R : a ⟶ b) :
    embed1 (R°) = matRecip (embed1 R) := rfl

/-- `embed1` preserves intersection. -/
theorem embed1_inter {a b : 𝒜} (R S : a ⟶ b) :
    embed1 (R ∩ S) = matInter (embed1 R) (embed1 S) := rfl

/-- `embed1` preserves union and zero. -/
theorem embed1_union {a b : 𝒜} (R S : a ⟶ b) :
    embed1 (R ∪ S) = matUnion (embed1 R) (embed1 S) := rfl

theorem embed1_zero {a b : 𝒜} :
    embed1 (𝟘 : a ⟶ b) = matZero := rfl

end Embed1

-- BOOK §2.342: `embed1` also preserves division when 𝒜 is a DivisionAllegory.
section Embed1Div

variable {𝒜 : Type u} [DivisionAllegory 𝒜]

/-- `embed1` preserves division: `embed1 (R/S) = matDiv (embed1 R) (embed1 S)`. -/
theorem embed1_div {a b c : 𝒜} (R : a ⟶ c) (S : b ⟶ c) :
    embed1 (R / S) = @matDiv 𝒜 _ (unitObj a) (unitObj b) (unitObj c) (embed1 R) (embed1 S) := by
  funext i j; simp only [embed1, matDiv, unitObj]
  letI hlo : LinearOrder PUnit := Classical.linearOrder PUnit
  have hne : (Finset.univ (α := PUnit)).Nonempty := ⟨PUnit.unit, Finset.mem_univ _⟩
  simp [hne]
  -- foldMeet {unit} hne (fun _ => R / S) = R / S
  simp [foldMeet, Finset.erase_singleton, Finset.fold_empty]
  -- Need: Finset.univ.min' hne = PUnit.unit
  -- This depends on the linear order; we check the fold is R/S.
  -- With s = {PUnit.unit} and erase gives ∅, fold ∅ init = init = R/S. ✓
  congr 1
  -- Need: s.min' hne = PUnit.unit  and  R PUnit.unit / S PUnit.unit = R / S
  simp

end Embed1Div

/-! ## §I  Summary: §ref table -/
-- §2.216  Allegory (MatObj 𝒜)                : instAllegoryMat           [PROVED]
-- §2.216  DistributiveAllegory (MatObj 𝒜)    : instDistributiveAllegoryMat [PROVED]
-- §2.342  DivisionAllegory (MatObj 𝒜)        : instDivisionAllegoryMat   [PROVED]
-- §2.342  embed1 faithful + preserves structure : embed1_injective, embed1_{comp,recip,inter,union,zero,div} [PROVED]
-- BOOK §2.342: "A⁺ is a division allegory" — the matrix allegory IS the positive reflection A⁺
-- when objects = finite families (see §2.216 AlgMat in S2_2.lean for the original AlgMat type).
-- The instDivisionAllegoryMat instance gives the full §2.342 statement for Mat 𝒜.

end Freyd.Alg.Mat
