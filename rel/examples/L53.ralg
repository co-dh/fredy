-- LeetCode 53 — Maximum Subarray (Kadane) — as an evalP FOLD (cf. leet/L53.lean).
-- Faithful: the fold actually computes over the real input array; nothing pre-baked.
-- carrier = (curBest ending here, bestSoFar).  step: cur' = max(x, cur+x); best' = max(best, cur').
prog maxsub = cata (x => (x, x)) (m x => (max x (fst m + x), max (snd m) (max x (fst m + x)))) ; fn (a => snd a)

-- LeetCode example: [-2,1,-3,4,-1,2,1,-5,4] -> 6  (the subarray [4,-1,2,1]).
run maxsub [-2, 1, -3, 4, -1, 2, 1, -5, 4]
