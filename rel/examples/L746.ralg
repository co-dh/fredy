-- LeetCode 746 — Min Cost Climbing Stairs — as an evalP FOLD (cf. leet/L746.lean).
-- carrier = (dp[i-1], dp[i]) where dp[i] = cost[i] + min(dp[i-1], dp[i-2]).  answer = min(dp[n-1], dp[n-2]).
-- base (x => (0, x)) seeds (dp[-1]=0, dp[0]=cost[0]).
prog climb = cata (x => (0, x)) (a x => (snd a, x + min (fst a) (snd a))) ; fn (a => min (fst a) (snd a))

-- [10,15,20] -> 15  (start at 15, step to top).
run climb [10, 15, 20]
-- [1,100,1,1,1,100,1,1,100,1] -> 6.
run climb [1, 100, 1, 1, 1, 100, 1, 1, 100, 1]
